emoss:On("Play", function(player, ename)
	local pd = data[player.UserId]
	local asset: any = require(res.Universal.Asset)
	local maid: any = require(res.Common.Maid)
	local uh = maid.new()

	if not pd.Inventory.Emotes[ename] then
		return
	end
	if not pd.Inventory.Emotes[ename].Equipped or not pd.Inventory.Emotes[ename].Purchased then
		return
	end

	local found = assets.Emotes:FindFirstChild(ename)
	if found then
		local ac = found:FindFirstChild("Accessories")
		efx[player] = {
			Connections = uh
		}
		if ac then
			for _, v in pairs(ac:GetChildren()) do
				if not player.Character:FindFirstChild(v.Name) then
					v = v:Clone()
					v.Parent = player.Character
					table.insert(efx[player], v)
				end
			end
		end
		emoss:FireClient(player, "Play")
		local parent = player.Character
		uh:Mark(player.Character.Humanoid.AnimationPlayed:Connect(function(anim)
			local newmaid = maid.new()
			local function hetter(f: any): any
				return function(h)
					if not parent then
						return
					end
					local fo = parent:FindFirstChild(h)
					return fo and f(fo)
				end
			end
			local function transparency(model, vis)
				for _, v in pairs(model:GetChildren()) do
					if v:IsA("BasePart") then
						v.Transparency = vis and 0 or 1
					end
				end
			end
			newmaid:Mark(anim:GetMarkerReachedSignal("Appear"):Connect(hetter(function(n)
				transparency(n, true)
			end)))
			newmaid:Mark(anim:GetMarkerReachedSignal("Hide"):Connect(hetter(function(n)
				transparency(n, false)
			end)))
			local emote = nil
			newmaid:Mark(anim:GetMarkerReachedSignal("Index"):Connect(function(n)
				emote = asset("Emotes", n)
			end))
			newmaid:Mark(anim:GetMarkerReachedSignal("Event"):Connect(function(name)
				if emote then
					local effects: any = emote.Effects
					if effects then
						local fx = effects[name]
						if fx then
							fx(newmaid, parent, anim)
						end
					end
				end
			end))
			anim.Stopped:Wait()
			newmaid:Sweep()
		end))
	end
end)

emoss:On("Stop", function(player)
	if efx[player] then
		if efx[player].Connections == nil then return end
		efx[player].Connections:Sweep()
		efx[player].Connections = nil
		for _, v in pairs(efx[player]) do
			v:Destroy()
		end
		table.clear(efx[player])
		efx[player] = nil
		emoss:FireClient(player, "Stop")
	end
end)

packages:On("Purchase", function(player: any, tower, skin, ptype, price)
	local pd = data[player.UserId]
	if not pd.Inventory.Troops[tower].Purchased then
		return false
	end
	if ptype == "Coins" and pd.Inventory.Troops[tower].Purchased then
		local coin = pd.Stats.Coins
		if price <= 0 or player.Coins.Value <= 0 or coin <= 0 then
			return false
		end

		local func = script.Parent.dailyidk.Function:Invoke()
		local canbuy = false
		local shopdata = nil

		for i, v in pairs(func.Coins) do
			if v.Troop == tower and v.Skin == skin then
				canbuy = true
				shopdata = v
				break
			end
		end

		if not canbuy or not shopdata then
			return false
		end

		price = shopdata.Price or 100

		if player.Coins.Value >= price and not table.find(pd.Inventory.Skins[tower], skin) then
			pd.Stats.Coins -= price
			player.Coins.Value -= price
			table.insert(pd.Inventory.Skins[tower], skin)
			session:FireClient(player, "Update", "Inventory.Skins", pd.Inventory.Skins)
			return true
		end

	elseif ptype == "Robux" and pd.Inventory.Troops[tower].Purchased then
		if price <= 0 or player.Gems.Value <= 0 or pd.Stats.Gems <= 0 then
			return false
		end

		local func = script.Parent.dailyidk.Function:Invoke()
		local canbuy = false
		local shopdata = nil

		for i, v in pairs(func.Robux) do
			if v.Troop == tower and v.Skin == skin then
				canbuy = true
				shopdata = v
				break
			end
		end

		if not canbuy or not shopdata then
			return false
		end

		price = shopdata.Price or 100

		if player.Gems.Value >= price and not table.find(pd.Inventory.Skins[tower], skin) then
			pd.Stats.Gems -= price
			player.Gems.Value -= price
			table.insert(pd.Inventory.Skins[tower], skin)
			session:FireClient(player, "Update", "Inventory.Skins", pd.Inventory.Skins)
			return true
		end
	end

	return false
end)

