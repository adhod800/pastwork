local checkrank = require(res.Universal.CheckRank)
local sessionsrequests: any = nil

local function getsessions()
	local datasaves = {}

	if sessionsrequests and tick() - sessionsrequests.time >= 60 then
		sessionsrequests = nil
	end

	if sessionsrequests then
		return sessionsrequests.data
	end

	local success, keyinstances: DataStoreKeyPages = pcall(function()
		return matchstore:ListKeysAsync(nil, 100, nil, true)
	end)
	if success and keyinstances then
		for _, instance: DataStoreKey in pairs(keyinstances:GetCurrentPage()) do
			local s, r = pcall(function()
				return matchstore:GetAsync(instance.KeyName)
			end)
			if s and r and r.ReservedId then
				datasaves[instance.KeyName] = r
			end
		end

		sessionsrequests = {
			time = tick(),
			data = datasaves
		}
	end
	return datasaves :: any
end

ss.GetSessions.OnInvoke = getsessions

network.Channel("SessionSync"):On("GetSessions", function(player)
	local ableto = checkrank(player)
	if typeof(ableto) == "string" then
		warn(ableto)
		return ableto
	end

	local result = getsessions()
	return result
end)

network.Channel("SessionSync"):On("CheckRejoin", function(player)
	return false
end)

network.Channel("SessionSync"):On("RequestRejoin", function(player)
	local success, pdata, calls = nil, nil, 0
	repeat
		calls += 1
		success, pdata = pcall(function()
			return matchstore:GetAsync(player.UserId)
		end)
	until success and pdata or calls >= 5

	if pdata and pdata.ReservedId ~= nil then
		return safeteleport(gamedata("Game"), pdata.ReservedId, { player }, nil)
	end

	return false
end)

network.Channel("SessionSync"):On("RemoveRejoin", function(player)
	local success, pdata, calls = nil, nil, 0
	repeat
		calls += 1
		success, pdata = pcall(function()
			return matchstore:GetAsync(player.UserId)
		end)
	until success and pdata or calls >= 5

	if pdata then
		matchstore:RemoveAsync(player.UserId)
		return true
	end

	return false
end)

