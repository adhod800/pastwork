inventory:On("Execute", function(player, typ, act, contents): (any)
	local timeout = tick()
	repeat
		task.wait()
		if tick() - timeout > 60 then return nil end
	until data[player.UserId]
	local pd = data[player.UserId]

	if typ == "GetStats" then
		return pd.Stats
	end

	if typ == "Troops" then
		if act == "Skin" then
			local skinname = contents.Skin
			local tname = contents.Troop
			local inv = pd.Inventory
			if table.find(inv.Skins[tname], skinname) then
				inv.Troops[tname].Skin = skinname
				session:FireClient(player, "Update", "Inventory.Troops", inv.Troops)
				session:FireClient(player, "Update", "Inventory.Skins", inv.Skins)
			else
				error("skin not owned bruh")
			end
		end
		if act == "GoldenPerks" then
			print("Updating Golden perk")
			local name = contents.Troop
			local enabl = contents.Enabled
			local ab = pd.Inventory.Troops

			if ab[name] and table.find(pd.Inventory.Skins[name], "Golden") then
				ab[name].GoldenPerks = enabl
			else
				warn("bruh no gold skin owned")
			end

			session:FireClient(player, "Update", "Inventory.Troops", ab)
		end

		if act == "PlatinumPerks" then
			print("Updating Platinum perk")
			local name = contents.Troop
			local enabl = contents.Enabled
			local ab = pd.Inventory.Troops

			if ab[name] and table.find(pd.Inventory.Skins[name], "Platinum") then
				ab[name].PlatinumPerks = enabl
				print("platinum perk yay")
			else
				warn("bruh no plat skin owned")
			end

			session:FireClient(player, "Update", "Inventory.Troops", ab)
		end

		if act == "Remove" or act == "Add" then
			if table.find(pd.Equipped.Troops, contents.Name) then
				act = "Remove"
			else
				act = "Add"
			end
		end

		if act == "Remove" then
			local tname = contents.Name
			local equiptrop = pd.Equipped.Troops
			if table.find(equiptrop, tname) then
				pd.Inventory.Troops[tname].Equipped = false
				table.remove(equiptrop, table.find(equiptrop, tname))
			else
				error("thingie not equipped what what")
			end
			session:FireClient(player, "Update", "Equipped.Troops", equiptrop)
			session:FireClient(player, "Update", "Inventory.Troops", pd.Inventory.Troops)
		end
		if act == "Add" then
			local tname = contents.Name
			local equiptrop = pd.Equipped.Troops
			if not pd.Inventory.Troops[tname].Purchased then
				return
			end
			if not table.find(equiptrop, tname) then
				table.insert(equiptrop, tname)
				pd.Inventory.Troops[tname].Equipped = true
				if pd.Stats.Level >= 10 then
					pd.MaxTroopEquip = 5
				else
					pd.MaxTroopEquip = 4
				end
				if #equiptrop > pd.MaxTroopEquip then
					local n = equiptrop[1]
					pd.Inventory.Troops[n].Equipped = false
					table.remove(equiptrop, 1)
				end
			else
				error("thingie equipped what what")
			end
			session:FireClient(player, "Update", "Equipped.Troops", equiptrop)
			session:FireClient(player, "Update", "Inventory.Troops", pd.Inventory.Troops)
		end
	end

	if typ == "Emotes" then
		if act == "Add" then
			local tname = contents.Name
			local pos = contents.Position
			if not pd.Inventory.Emotes[tname] then
				pd.Inventory.Emotes[tname] = {
					Equipped = false
				}
			end
			if not pd.Inventory.Emotes[tname].Purchased then
				return
			end
			local equiptrop = pd.emoteequop
			local yes = equiptrop[pos]
			if pd.Inventory.Emotes[yes] then
				pd.Inventory.Emotes[yes].Equipped = false
			end
			equiptrop[pos] = tname
			if pd.Inventory.Emotes[tname] then
				pd.Inventory.Emotes[tname].Equipped = true
			end
			session:FireClient(player, "Update", "Equipped.Emotes", equiptrop)
			session:FireClient(player, "Update", "Inventory.Emotes", pd.Inventory.Emotes)
		end
	end

	if typ == "Tags" then
		if act == "Equip" then
			local nametaginv = pd.Inventory.Nametags
			local tagname = contents["Name"]

			if table.find(nametaginv, tagname) and pd.Stats.Tag ~= tagname then
				pd.Stats.Tag = tagname
				player.Tag.Value = tagname
				session:FireClient(player, "Update", "Inventory.Nametags", pd.Inventory.Nametags)
				return true
			end

			return false
		end
	end

	if typ == "Crates" then
		if act == "Count" then
			return pd.Inventory.Crates[contents.Name]
		end
		if act == "Blacklist" then
			return skinsblacklist
		end
		if act == "Get" then
			return {
				Common = 0,
				Uncommon = 0,
				Rare = 0,
				Legendary = 0
			}
		end
		if act == "Open" then
			local name = contents.Name
			if not pd.Inventory.Crates[name] or pd.Inventory.Crates[name] <= 0 then
				return
			end
			local tower = {}
			local crate = assets.Crates:FindFirstChild(name)
			local datamod2 = require(crate.Data)
			local ownedskins = pd.Inventory.Skins
			for _, t in pairs(assets.Troops:GetChildren()) do
				if pd.Inventory.Troops[t.Name] and pd.Inventory.Troops[t.Name].Purchased == true or table.find(pd.Equipped.Troops, t.Name) then
					table.insert(tower, t)
				end
			end
			local twskins = {}
			for _, t in pairs(tower) do
				for i, _ in pairs(datamod2.Skins) do
					if t:FindFirstChild("Skins"):FindFirstChild(i) and ownedskins[t.Name] then
						local bl = skinsblacklist and skinsblacklist[t.Name]
						if bl and table.find(bl, i) then
							continue
						end
						if not table.find(ownedskins[t.Name], i) then
							if not table.find(twskins, t:FindFirstChild("Skins"):FindFirstChild(i)) then
								table.insert(twskins, t:FindFirstChild("Skins"):FindFirstChild(i))
							end
						end
					end
				end
			end
			if #twskins > 0 then
				local skin = twskins[Random.new():NextInteger(1, #twskins)]
				local twr = skin.Parent.Parent
				table.insert(ownedskins[tostring(twr.Name)], skin.Name)
				pd.Inventory.Crates[name] -= 1
				task.delay(0.2, function()
					session:FireClient(player, "Update", "Inventory.Skins", pd.Inventory.Skins)
					session:FireClient(player, "Update", "Inventory.Crates", pd.Inventory.Crates)
				end)
				return {
					Model = crate.Model,
					Animation = crate.Animation,
					Skin = skin.Name,
					Troop = twr.Name
				}
			end
		end
	end
	return
end)

shop:On("Purchase", function(player, contents)
	local timeout = tick()
	repeat
		task.wait()
		if tick() - timeout > 60 then return "CLOSE" end
	until data[player.UserId]
	local pd: { [string]: any } = data[player.UserId]
	local typ = contents.Type
	local stats = pd.Stats
	local modname
	if typ == "Troop" then
		modname = "Shop"
	else
		modname = "Data"
	end
	local name = contents.Name
	local shopmod = require(assets:FindFirstChild(`{typ}s`):FindFirstChild(name)[modname])
	local pice = shopmod.Price
	local pricetype = pice.Type
	local val = pice.Value
	local fulltyp = `{typ}s`

	if pricetype == "Free" then
		if typ == "Troop" then
			pd.Inventory[fulltyp][name].Purchased = true
		elseif typ == "Crate" then
			pd.Inventory[fulltyp][name] += 1
		elseif typ == "Emote" then
			pd.Inventory[fulltyp][name] = {
				Equipped = false,
				Purchased = true
			}
		end
		session:FireClient(player, "Update", "Equipped.Troops", pd.Equipped.Troops)
		session:FireClient(player, "Update", `Inventory.{fulltyp}`, pd.Inventory[fulltyp])
		return "SUCCESS"
	end

	local stat = player:FindFirstChild(pricetype)
	if stats[pricetype] >= val then
		stat.Value -= val
		stats[pricetype] -= val
		if typ == "Troop" then
			pd.Inventory[fulltyp][name].Purchased = true
		elseif typ == "Crate" then
			pd.Inventory[fulltyp][name] += 1
		elseif typ == "Emote" then
			pd.Inventory[fulltyp][name] = {
				Equipped = false,
				Purchased = true
			}
		end
		session:FireClient(player, "Update", "Equipped.Troops", pd.Equipped.Troops)
		session:FireClient(player, "Update", `Inventory.{fulltyp}`, pd.Inventory[fulltyp])
		return "SUCCESS"
	end
	return "CLOSE"
end)

